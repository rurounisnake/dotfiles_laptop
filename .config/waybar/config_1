  "format-source-muted": "´ä▒",
  "format-icons": {
    "headphone": "´Çą",
    "hands-free": "´ľÉ",
    "headset": "­čÄž",
    "phone": "´éĽ",
    "portable": "´éĽ",
    "car": "´ć╣",
    "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
  },
  "on-click": "pavucontrol"
},
"mpd": {
  "format": "{stateIcon} {artist} - {title}",
  "format-disconnected": "­čÄÂ",
  "format-stopped": "ÔÖ¬",
  "interval": 10,
  "consume-icons": {
    "on": "´âä " // Icon shows only when "consume" is on
  },
  "random-icons": {
    "off": "<span color=\"#f53c3c\">´ü┤</span> ", // Icon grayed out when "random" is off
    "on": "´ü┤ "
  },
  "repeat-icons": {
    "on": "´Ç× "
  },
  "single-icons": {
    "on": "´Ç×1 "
  },
  "state-icons": {
    "paused": "´üî",
    "playing": "´üő"
  },
  "tooltip-format": "MPD (connected)",
  "tooltip-format-disconnected": "MPD (disconnected)",
  "max-length": 35
},
"custom/recorder": {
    "format": "´ÇŻ Rec",
    "format-disabled": "´ÇŻ Off-air", //An empty format will hide the module.
    "return-type": "json",
    "interval": 1,
    "exec": "echo '{\"class\": \"recording\"}'",
    "exec-if": "pgrep wf-recorder",
},
"custom/audiorec": {
    "format": "ÔÖČ Rec",
    "format-disabled": "ÔÖČ Off-air", //An empty format will hide the module.
    "return-type": "json",
    "interval": 1,
    "exec": "echo '{\"class\": \"audio recording\"}'",
    "exec-if": "pgrep ffmpeg",
},
"hyprland/window": {
    "format": "{initialTitle}",
    "max-length": 20,
    "rewrite": {
        // if any window is focused display Finder
     "^(?!.*\\S).*": ""
    }
},
"clock": {
    "format": "{:%H:%M}     ",
},
"custom/date": {
    // put you user here
    "exec": "~/.config/waybar/scripts/custom_date.sh",
    "interval": 60,
    "tooltip": false
},
"custom/tailscale": {
    "exec": "~/.config/waybar/scripts/waybar-tailscale.sh --status",
    "on-click": "exec ~/.config/waybar/scripts/waybar-tailscale.sh --toggle",
    "exec-on-event": true,
    "format": "ts: {icon}",
    "format-icons": {
        "connected": "on",
        "stopped": "off"
    },
    "tooltip": true,
    "return-type": "json",
    "interval": 3
}
}
