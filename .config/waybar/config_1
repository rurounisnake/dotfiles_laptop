  "max-length": 20,
  "min-length": 6,
  // "format-alt": "{essid}",
  "on-click": "networkmanager_dmenu",
},
"idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
        "activated": "´ü«",
        "deactivated": "´ü░"
    }
},
"backlight": {
    // "device": "acpi_video1",
    "format": "{icon}  {percent}%",
    "format-icons": ["´âź", "´âź"],
    "on-scroll-down": "brightnessctl -c backlight set 1%-",
    "on-scroll-up": "brightnessctl -c backlight set +1%"
},
"pulseaudio": {
  // "scroll-step": 1, // %, can be a float
  // "format": "{icon}  {volume}% {format_source}",
  "format": "{icon}    {volume}%",
  "format-bluetooth": "{icon}´Őö {volume}% {format_source}",
  "format-bluetooth-muted": "´ĹŽ {format_source}",
