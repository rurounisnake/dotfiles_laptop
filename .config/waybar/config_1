{
//"layer": "overlay",
// "mode": "overlay",
"position": "bottom",
"height": 23,
"margin": 0,
"spacing": 10,
"border-size": 2,
"padding": 10,

// "modules-left": ["custom/launcher","hyprland/workspaces"],
"modules-left": ["hyprland/workspaces"],
// "modules-center": ["hyprland/window"],
"modules-right":  ["cpu","memory","tray","network","backlight","battery","pulseaudio","custom/date","clock"],

"battery": {
  "interval": 30,
  "states": {
  "warning": 30,
  "critical": 15
  },
  "format": "{icon}    {capacity}%",
  "format-full": "{icon}    {capacity}%",
  "format-charging": "´ĺĺ    {capacity}%",
  "format-plugged": "´ĺĺ    {capacity}%",
  "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
  "on-click": "gnome-power-statistics"
},
"hyprland/workspaces": {
     "sort-by-name": true,
     "on-click": "activate"
},
"hyprland/window": {
    "max-length": 200,
    "separate-outputs": true
},
"sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
},
"tray": {
    "icon-size": 16,
    "spacing": 6
},
// Power Menu
"custom/exit": {
    "format": "´ÇĹ ",
    "on-click": "nwg-bar",
    "tooltip": false
},
"bluetooth": {
	"format": "´Őö",
