	// "format-connected-battery": "´Őö {device_alias} {device_battery_percentage}%",
	// "format-device-preference": [ "device1", "device2" ], // preference list deciding the displayed device
	"tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
	"tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
	"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
	"tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
	"on-click": "bluedevil-wizard"
},
"custom/corne": {
    "exec": "python ~/.config/waybar/scripts/zmk_split-battery_waybar.py",
    "return-type": "json",
    "format": "{}",
    "interval": 60
},
"user": {
    "format": "{user} ",
    "interval": 60,
    "icon": true
},
"custom/launcher": {
    "format":"ˇ░úç",
    "on-click": "exec nwg-drawer",
    "tooltip": false,
},
"cpu": {
    "format": "´őŤ&#8239;    {usage}%",
    "tooltip": false,
    "on-click": "kitty -e 'htop'"
},
"memory": {
    "interval": 30,
    "format": "´âë   {used:0.2f} GB",
    "max-length": 10,
    "tooltip": false,
    "warning": 70,
    "critical": 90
},
"network": {
  "interval": 2,
  "format-wifi": "´çź     {signalStrength}%",
  "format-ethernet": "´âü {bandwidthDownBytes} ´ÇÖ   {bandwidthUpBytes} ´éô ",
  "format-linked": " {ipaddr}",
